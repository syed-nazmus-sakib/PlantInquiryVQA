# ============================================================================
# PlantInquiryVQA — environment variables
# Copy this file to .env and fill in your API keys.  .env is gitignored.
# ============================================================================

# --- Model provider keys (only fill in those you plan to use) ----------------
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=

# --- Dataset / image roots (defaults work if you cloned the repo normally) --
# PLANTINQUIRY_HOME defaults to the repo root
PLANTINQUIRY_HOME=
# Override if you store the 24,950 image files outside the repo (e.g., local
# cache of the HuggingFace dataset).
PLANTINQUIRY_IMAGE_DIR=


